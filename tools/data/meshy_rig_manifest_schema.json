{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MeshyRigManifest",
  "type": "object",
  "properties": {
    "version": { "type": "string" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "character_name": { "type": "string" },
          "source_task_type": { "enum": ["text-to-3d", "image-to-3d", "multi-image-to-3d", "model_url"] },
          "source_task_id": { "type": "string" },
          "rig_task_id": { "type": "string" },
          "status": { "enum": ["pending", "rigging", "validation", "passed", "failed", "rejected"] },
          "created_at": { "type": "string", "format": "date-time" },
          "height_meters": { "type": "number", "minimum": 0.1 },
          "downloads": {
            "type": "object",
            "properties": {
              "rigged_glb": { "type": "string" },
              "rigged_fbx": { "type": "string" },
              "walking_glb": { "type": "string" },
              "running_glb": { "type": "string" }
            }
          },
          "validation": {
            "type": "object",
            "properties": {
              "face_count": { "type": "integer" },
              "bone_count": { "type": "integer" },
              "required_bones_present": { "type": "boolean" },
              "no_bone_cycles": { "type": "boolean" },
              "bind_pose_feet_y": { "type": "number" },
              "bind_pose_head_forward_axis": { "type": "string" },
              "g1_retarget_finiteness": { "type": "boolean" },
              "rich_retarget_finiteness": { "type": "boolean" },
              "skin_matrices_positive_determinant": { "type": "boolean" },
              "motionbricks_seed_pass": { "type": "boolean" },
              "errors": { "type": "array", "items": { "type": "string" } },
              "warnings": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "required": ["id", "character_name", "source_task_type", "status", "created_at"]
      }
    }
  },
  "required": ["version", "entries"]
}
